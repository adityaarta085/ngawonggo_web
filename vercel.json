{
  "crons": [
    {
      "path": "/api/cron-national-news",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/health/:path*",
      "destination": "/api/health/:path*"
    },
    {
      "source": "/:path*/health",
      "destination": "/api/health-path?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}